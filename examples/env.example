# ~/.config/spark-mcp/.env example
# Never commit a real .env to git. Permissions must be 0o600.

# Required: at least 32 characters. Generate via `spark-mcp init`.
SPARK_MCP_AUTH_TOKEN=<your-token-here>

# Required: SSH user for worker access.
SPARK_MCP_SSH_USER=<your-username>

# Required: path to an ed25519 (or other) private key, mode 0o600.
SPARK_MCP_SSH_KEY_PATH=~/.ssh/id_ed25519_spark
