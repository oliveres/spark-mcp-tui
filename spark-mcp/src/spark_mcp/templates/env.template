# ~/.config/spark-mcp/.env
# Secrets for spark-mcp. Never commit this file to git. Permissions: chmod 600.

# MCP server authentication token (required; generated by `spark-mcp init`).
SPARK_MCP_AUTH_TOKEN=

# SSH credentials for worker node access (required).
SPARK_MCP_SSH_USER=
SPARK_MCP_SSH_KEY_PATH=
